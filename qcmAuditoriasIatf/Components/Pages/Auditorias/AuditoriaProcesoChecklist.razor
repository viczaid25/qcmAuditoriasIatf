@page "/auditorias/{auditoriaId:int}/procesos/{auditoriaProcesoId:int}/checklist"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using qcmAuditoriasIatf.Models.Auditorias
@using qcmAuditoriasIatf.Models.Catalogos
@using qcmAuditoriasIatf.Models.Hallazgos
@inject qcmAuditoriasIatf.Data.ApplicationDbContext Db
@inject NavigationManager Nav

@attribute [Authorize]

@if (!string.IsNullOrWhiteSpace(errorMsg))
{
    <div class="alert alert-danger">@errorMsg</div>
}

@if (cargando)
{
    <div class="checklist-loading">
        <div class="checklist-skeleton checklist-skeleton-hero"></div>
        <div class="checklist-metrics">
            <div class="checklist-skeleton checklist-skeleton-card"></div>
            <div class="checklist-skeleton checklist-skeleton-card"></div>
            <div class="checklist-skeleton checklist-skeleton-card"></div>
            <div class="checklist-skeleton checklist-skeleton-card"></div>
        </div>
        <div class="checklist-skeleton checklist-skeleton-table"></div>
    </div>
}
else if (ap is null)
{
    <section class="panel-card">
        <div class="empty-state">
            <div class="empty-title">No se encontró el proceso de auditoría</div>
            <div class="empty-text">Verifica el proceso seleccionado o vuelve al detalle de la auditoría.</div>

            <button type="button" class="hero-btn primary mt-3" @onclick="Volver">
                Volver
            </button>
        </div>
    </section>
}
else
{
    <div class="checklist-page">
        <section class="checklist-hero">
            <div>
                <span class="checklist-kicker">Checklist de proceso</span>
                <h1>@ap.Proceso?.Codigo - @ap.Proceso?.Nombre</h1>

                <div class="checklist-meta">
                    <span class="meta-chip">
                        Auditor asignado:
                        <strong>@(string.IsNullOrWhiteSpace(ap.AuditorAsignadoId) ? "Sin asignar" : ap.AuditorAsignadoId)</strong>
                    </span>

                    @if (!string.IsNullOrWhiteSpace(ap.LineaNombre))
                    {
                        <span class="meta-chip">
                            Línea:
                            <strong>@ap.LineaNombre</strong>
                        </span>
                    }

                    <span class="meta-chip">
                        Preguntas:
                        <strong>@rows.Count</strong>
                    </span>
                </div>

                <p class="hero-text">
                    Registra el resultado del checklist, evidencia, comentarios y genera hallazgos cuando una respuesta sea “No Cumple”.
                </p>
            </div>

            <div class="checklist-hero-actions">
                <button type="button" class="hero-btn primary" @onclick="Guardar" disabled="@guardando">
                    @(guardando ? "Guardando..." : "Guardar checklist")
                </button>

                <button type="button" class="hero-btn" @onclick="Volver" disabled="@guardando">
                    Volver
                </button>
            </div>
        </section>

        <section class="checklist-metrics">
            <div class="metric-card">
                <div class="metric-label">Total</div>
                <div class="metric-value">@rows.Count</div>
                <div class="metric-note">Preguntas activas del proceso</div>
            </div>

            <div class="metric-card">
                <div class="metric-label">Cumple</div>
                <div class="metric-value">@TotalCumple</div>
                <div class="metric-note">Respuestas conformes</div>
            </div>

            <div class="metric-card">
                <div class="metric-label">No cumple</div>
                <div class="metric-value">@TotalNoCumple</div>
                <div class="metric-note">Requieren atención</div>
            </div>

            <div class="metric-card">
                <div class="metric-label">Hallazgos</div>
                <div class="metric-value">@TotalHallazgos</div>
                <div class="metric-note">Ya generados desde checklist</div>
            </div>
        </section>

        @if (rows.Count == 0)
        {
            <section class="panel-card">
                <div class="empty-state compact">
                    No hay preguntas activas para este proceso.
                </div>
            </section>
        }
        else
        {
            <section class="panel-card">
                <div class="panel-head">
                    <div>
                        <h2>Preguntas del checklist</h2>
                        <p class="panel-subtitle">Actualiza la evaluación, evidencia y comentarios por cada pregunta.</p>
                    </div>

                    <span class="panel-badge">@rows.Count registro(s)</span>
                </div>

                <div class="table-wrap">
                    <table class="checklist-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Pregunta</th>
                                <th>Resultado</th>
                                <th>Evidencia</th>
                                <th>Comentarios</th>
                                <th class="text-end">Hallazgo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < rows.Count; i++)
                            {
                                var row = rows[i];

                                <tr @key="row.PreguntaId">
                                    <td>
                                        <span class="index-pill">@(i + 1)</span>
                                    </td>

                                    <td>
                                        <div class="question-title">@row.Pregunta</div>
                                        @if (!string.IsNullOrWhiteSpace(row.Requisito))
                                        {
                                            <div class="question-subtitle">@row.Requisito</div>
                                        }
                                    </td>

                                    <td class="result-column">
                                        <div class="result-chip-group">
                                            <button type="button"
                                                    class='@GetResultadoButtonClass(row.Cumple, "Pendiente")'
                                                    @onclick='() => SetResultado(row, "Pendiente")'
                                                    disabled="@guardando">
                                                Pendiente
                                            </button>

                                            <button type="button"
                                                    class='@GetResultadoButtonClass(row.Cumple, "Cumple")'
                                                    @onclick='() => SetResultado(row, "Cumple")'
                                                    disabled="@guardando">
                                                Cumple
                                            </button>

                                            <button type="button"
                                                    class='@GetResultadoButtonClass(row.Cumple, "No Cumple")'
                                                    @onclick='() => SetResultado(row, "No Cumple")'
                                                    disabled="@guardando">
                                                No Cumple
                                            </button>

                                            <button type="button"
                                                    class='@GetResultadoButtonClass(row.Cumple, "No Aplica")'
                                                    @onclick='() => SetResultado(row, "No Aplica")'
                                                    disabled="@guardando">
                                                No Aplica
                                            </button>
                                        </div>
                                    </td>

                                    <td>
                                        <InputTextArea class="form-control form-control-sm table-textarea"
                                                       rows="3"
                                                       @bind-Value="row.Evidencia"
                                                       disabled="@guardando" />
                                    </td>

                                    <td>
                                        <InputTextArea class="form-control form-control-sm table-textarea"
                                                       rows="3"
                                                       @bind-Value="row.Comentarios"
                                                       disabled="@guardando" />
                                    </td>

                                    <td class="text-end">
                                        @if (row.TieneHallazgo && row.HallazgoId is not null)
                                        {
                                            <button type="button"
                                                    class="table-btn"
                                                    @onclick="() => IrVerHallazgo(row.HallazgoId.Value)"
                                                    disabled="@guardando">
                                                Ver hallazgo
                                            </button>
                                        }
                                        else if (row.Cumple == "No Cumple")
                                        {
                                            <button type="button"
                                                    class="table-btn table-btn-danger"
                                                    @onclick="() => IrNuevoHallazgo(row.PreguntaId)"
                                                    disabled="@guardando">
                                                Crear hallazgo
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="empty-inline">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="panel-card action-panel">
                <div class="action-panel-inner">
                    <div>
                        <h2>Acciones</h2>
                        <p class="panel-subtitle mb-0">
                            Guarda el checklist para conservar cambios en resultados, evidencia y comentarios.
                        </p>
                    </div>

                    <div class="action-buttons">
                        <button type="button" class="btn btn-primary btn-lg" @onclick="Guardar" disabled="@guardando">
                            @(guardando ? "Guardando..." : "Guardar checklist")
                        </button>

                        <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="Volver" disabled="@guardando">
                            Volver
                        </button>
                    </div>
                </div>
            </section>
        }
    </div>
}

@code {
    [Parameter] public int auditoriaId { get; set; }
    [Parameter] public int auditoriaProcesoId { get; set; }

    private bool cargando = true;
    private bool guardando;
    private string? errorMsg;

    private AuditoriaProceso? ap;
    private List<RowVm> rows = new();

    private int TotalCumple => rows.Count(x => x.Cumple == "Cumple");
    private int TotalNoCumple => rows.Count(x => x.Cumple == "No Cumple");
    private int TotalHallazgos => rows.Count(x => x.TieneHallazgo);

    private class RowVm
    {
        public int PreguntaId { get; set; }
        public string Pregunta { get; set; } = "";
        public string? Requisito { get; set; }

        public string Cumple { get; set; } = "Pendiente";
        public string? Evidencia { get; set; }
        public string? Comentarios { get; set; }

        public bool TieneHallazgo { get; set; }
        public int? HallazgoId { get; set; }
    }

    protected override async Task OnParametersSetAsync()
    {
        cargando = true;
        errorMsg = null;
        rows.Clear();

        ap = await Db.AuditoriaProcesos
            .Include(x => x.Proceso)
            .FirstOrDefaultAsync(x => x.AuditoriaProcesoId == auditoriaProcesoId && x.AuditoriaId == auditoriaId);

        if (ap is null)
        {
            cargando = false;
            return;
        }

        var preguntas = await Db.ChecklistPreguntas
            .Where(p => p.ProcesoId == ap.ProcesoId && p.Activo)
            .OrderBy(p => p.PreguntaId)
            .ToListAsync();

        var existentes = await Db.AuditoriaChecklists
            .Where(x => x.AuditoriaProcesoId == auditoriaProcesoId)
            .ToListAsync();

        var map = existentes.ToDictionary(x => x.PreguntaId, x => x);

        var faltantes = preguntas
            .Where(p => !map.ContainsKey(p.PreguntaId))
            .Select(p => new AuditoriaChecklist
            {
                AuditoriaProcesoId = auditoriaProcesoId,
                PreguntaId = p.PreguntaId,
                Cumple = "Pendiente",
                AuditorId = string.IsNullOrWhiteSpace(ap.AuditorAsignadoId) ? "sistema" : ap.AuditorAsignadoId!,
                FechaRegistro = DateTime.Now
            })
            .ToList();

        if (faltantes.Count > 0)
        {
            Db.AuditoriaChecklists.AddRange(faltantes);
            await Db.SaveChangesAsync();

            existentes = await Db.AuditoriaChecklists
                .Where(x => x.AuditoriaProcesoId == auditoriaProcesoId)
                .ToListAsync();

            map = existentes.ToDictionary(x => x.PreguntaId, x => x);
        }

        var hallazgos = await Db.Hallazgos
            .Where(h => h.AuditoriaProcesoId == auditoriaProcesoId && h.PreguntaId != null)
            .Select(h => new { PreguntaId = h.PreguntaId!.Value, h.HallazgoId })
            .ToListAsync();

        var hallazgoMap = hallazgos
            .GroupBy(x => x.PreguntaId)
            .ToDictionary(g => g.Key, g => g.First().HallazgoId);

        foreach (var p in preguntas)
        {
            map.TryGetValue(p.PreguntaId, out var r);
            hallazgoMap.TryGetValue(p.PreguntaId, out var hid);

            rows.Add(new RowVm
            {
                PreguntaId = p.PreguntaId,
                Pregunta = p.Pregunta,
                Requisito = p.Requisito,
                Cumple = string.IsNullOrWhiteSpace(r?.Cumple) ? "Pendiente" : r!.Cumple,
                Evidencia = r?.Evidencia,
                Comentarios = r?.Comentarios,
                TieneHallazgo = hid > 0,
                HallazgoId = hid > 0 ? hid : null
            });
        }

        cargando = false;
    }

    private async Task Guardar()
    {
        if (guardando) return;
        guardando = true;
        errorMsg = null;

        try
        {
            var entidades = await Db.AuditoriaChecklists
                .Where(x => x.AuditoriaProcesoId == auditoriaProcesoId)
                .ToListAsync();

            var map = entidades.ToDictionary(x => x.PreguntaId, x => x);

            foreach (var row in rows)
            {
                if (!map.TryGetValue(row.PreguntaId, out var e))
                    continue;

                e.Cumple = string.IsNullOrWhiteSpace(row.Cumple) ? "Pendiente" : row.Cumple;
                e.Evidencia = string.IsNullOrWhiteSpace(row.Evidencia) ? null : row.Evidencia.Trim();
                e.Comentarios = string.IsNullOrWhiteSpace(row.Comentarios) ? null : row.Comentarios.Trim();

                if (ap is not null && !string.IsNullOrWhiteSpace(ap.AuditorAsignadoId))
                    e.AuditorId = ap.AuditorAsignadoId!;

                e.FechaRegistro = DateTime.Now;
            }

            await Db.SaveChangesAsync();
            Nav.NavigateTo($"auditorias/{auditoriaId}");
        }
        catch (Exception ex)
        {
            errorMsg = ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private void SetResultado(RowVm row, string valor)
    {
        row.Cumple = valor;
    }

    private static string GetResultadoButtonClass(string? actual, string opcion)
    {
        var estado = GetCumpleClass(opcion);
        var activo = string.Equals(actual, opcion, StringComparison.OrdinalIgnoreCase) ? "active" : "";
        return $"result-chip {estado} {activo}".Trim();
    }

    private static string GetCumpleClass(string? valor)
    {
        var v = valor?.Trim().ToLowerInvariant() ?? string.Empty;

        if (v == "cumple")
            return "success";

        if (v == "no cumple")
            return "danger";

        if (v == "no aplica" || v == "n/a")
            return "neutral";

        return "pending";
    }

    private void IrNuevoHallazgo(int preguntaId) =>
        Nav.NavigateTo($"auditorias/{auditoriaId}/procesos/{auditoriaProcesoId}/checklist/{preguntaId}/hallazgo/nuevo");

    private void IrVerHallazgo(int hallazgoId) =>
        Nav.NavigateTo($"auditorias/{auditoriaId}/hallazgos/{hallazgoId}");

    private void Volver() => Nav.NavigateTo($"auditorias/{auditoriaId}");
}