@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using qcmAuditoriasIatf.Data
@using System.Security.Claims
@inject ApplicationDbContext Db

@attribute [Authorize]

@if (cargando)
{
    <div class="dashboard-loading">
        <div class="dashboard-skeleton dashboard-skeleton-lg"></div>
        <div class="dashboard-cards">
            <div class="dashboard-skeleton dashboard-skeleton-card"></div>
            <div class="dashboard-skeleton dashboard-skeleton-card"></div>
            <div class="dashboard-skeleton dashboard-skeleton-card"></div>
            <div class="dashboard-skeleton dashboard-skeleton-card"></div>
        </div>
    </div>
}
else
{
    <div class="dashboard-page">
        <section class="dashboard-hero">
            <div>
                <div class="dashboard-badge">Panel principal</div>
                <h1>Bienvenido, @nombreVisible</h1>
                <p>
                    Administra auditorías, procesos, equipo auditor y hallazgos desde un solo lugar.
                </p>
            </div>

            <div class="dashboard-hero-side">
                <div class="dashboard-hero-card">
                    <div class="dashboard-hero-label">Usuario de red</div>
                    <div class="dashboard-hero-value">@usuarioActualId</div>
                </div>
            </div>
        </section>

        <section class="dashboard-cards">
            <a class="dashboard-card" href="auditorias">
                <div class="dashboard-card-title">Auditorías</div>
                <div class="dashboard-card-value">@totalAuditorias</div>
                <div class="dashboard-card-text">Registros totales del sistema</div>
            </a>

            <a class="dashboard-card" href="procesos">
                <div class="dashboard-card-title">Procesos</div>
                <div class="dashboard-card-value">@totalProcesos</div>
                <div class="dashboard-card-text">Procesos dados de alta</div>
            </a>

            <a class="dashboard-card" href="auditores">
                <div class="dashboard-card-title">Auditores activos</div>
                <div class="dashboard-card-value">@totalAuditoresActivos</div>
                <div class="dashboard-card-text">Equipo disponible para asignación</div>
            </a>

            <a class="dashboard-card" href="auditorias">
                <div class="dashboard-card-title">Hallazgos abiertos</div>
                <div class="dashboard-card-value">@totalHallazgosAbiertos</div>
                <div class="dashboard-card-text">Pendientes de seguimiento o cierre</div>
            </a>
        </section>

        <section class="dashboard-grid">
            <div class="dashboard-panel">
                <h2>Acciones rápidas</h2>
                <div class="quick-actions">
                    <a href="auditorias/nueva" class="quick-action">Nueva auditoría</a>
                    <a href="procesos/nuevo" class="quick-action">Nuevo proceso</a>
                    <a href="auditores/nuevo" class="quick-action">Alta auditor</a>
                    <a href="auditorias" class="quick-action quick-action-outline">Ir a auditorías</a>
                </div>
            </div>

            <div class="dashboard-panel">
                <h2>Resumen operativo</h2>
                <ul class="summary-list">
                    <li>
                        <span>Hallazgos cerrados</span>
                        <strong>@totalHallazgosCerrados</strong>
                    </li>
                    <li>
                        <span>Hallazgos en proceso</span>
                        <strong>@totalHallazgosEnProceso</strong>
                    </li>
                    <li>
                        <span>Hallazgos abiertos</span>
                        <strong>@totalHallazgosAbiertos</strong>
                    </li>
                </ul>
            </div>
        </section>
    </div>
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool cargando = true;

    private string usuarioActualId = "sistema";
    private string nombreVisible = "Usuario";

    private int totalAuditorias;
    private int totalProcesos;
    private int totalAuditoresActivos;
    private int totalHallazgosAbiertos;
    private int totalHallazgosEnProceso;
    private int totalHallazgosCerrados;

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuario();
        await CargarDashboard();
        cargando = false;
    }

    private async Task CargarUsuario()
    {
        if (AuthenticationStateTask is null)
            return;

        var authState = await AuthenticationStateTask;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            usuarioActualId =
                user.FindFirst("pc_login_id")?.Value
                ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "sistema";

            nombreVisible =
                user.Identity?.Name
                ?? user.FindFirst(ClaimTypes.Name)?.Value
                ?? usuarioActualId;
        }
    }

    private async Task CargarDashboard()
    {
        totalAuditorias = await Db.Auditorias.CountAsync();
        totalProcesos = await Db.Procesos.CountAsync();
        totalAuditoresActivos = await Db.Auditores.CountAsync(a => a.Activo);
        totalHallazgosAbiertos = await Db.Hallazgos.CountAsync(h => h.Estatus == "Abierto");
        totalHallazgosEnProceso = await Db.Hallazgos.CountAsync(h => h.Estatus == "En Proceso");
        totalHallazgosCerrados = await Db.Hallazgos.CountAsync(h => h.Estatus == "Cerrado");
    }
}