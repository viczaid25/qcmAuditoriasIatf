@page "/auditorias/{auditoriaId:int}/procesos/{auditoriaProcesoId:int}/checklist/{preguntaId:int}/hallazgo/nuevo"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using qcmAuditoriasIatf.Models.Auditorias
@using qcmAuditoriasIatf.Models.Catalogos
@using qcmAuditoriasIatf.Models.External
@using qcmAuditoriasIatf.Models.Hallazgos
@using System.Security.Claims
@inject qcmAuditoriasIatf.Data.ApplicationDbContext Db
@inject NavigationManager Nav

@attribute [Authorize]

@if (!string.IsNullOrWhiteSpace(errorMsg))
{
    <div class="alert alert-danger">@errorMsg</div>
}

@if (cargando)
{
    <div class="nuevo-hallazgo-loading">
        <div class="nuevo-hallazgo-skeleton nuevo-hallazgo-skeleton-hero"></div>
        <div class="nuevo-hallazgo-grid">
            <div class="nuevo-hallazgo-skeleton nuevo-hallazgo-skeleton-form"></div>
            <div class="nuevo-hallazgo-skeleton nuevo-hallazgo-skeleton-side"></div>
        </div>
    </div>
}
else if (ap is null || pregunta is null)
{
    <section class="panel-card">
        <div class="empty-state">
            <div class="empty-title">No se encontró el contexto del hallazgo</div>
            <div class="empty-text">
                No fue posible cargar el proceso o la pregunta relacionada al checklist.
            </div>

            <button type="button" class="hero-btn primary mt-3" @onclick="Volver">
                Volver al checklist
            </button>
        </div>
    </section>
}
else
{
    <div class="nuevo-hallazgo-page">
        <section class="nuevo-hallazgo-hero">
            <div>
                <span class="nuevo-hallazgo-kicker">Alta de hallazgo</span>
                <h1>Nuevo hallazgo desde checklist</h1>

                <div class="hero-meta">
                    <span class="meta-chip">
                        Auditoría:
                        <strong>#@auditoriaId</strong>
                    </span>

                    <span class="meta-chip">
                        Proceso:
                        <strong>@ap.Proceso?.Codigo</strong>
                    </span>

                    @if (!string.IsNullOrWhiteSpace(ap.LineaNombre))
                    {
                        <span class="meta-chip">
                            Línea:
                            <strong>@ap.LineaNombre</strong>
                        </span>
                    }

                    <span class="meta-chip">
                        Auditor asignado:
                        <strong>@(string.IsNullOrWhiteSpace(ap.AuditorAsignadoId) ? "Sin asignar" : ap.AuditorAsignadoId)</strong>
                    </span>
                </div>

                <p class="hero-text">
                    Captura la no conformidad detectada, asigna responsables y registra la evidencia inicial del hallazgo.
                </p>
            </div>

            <div class="hero-actions">
                <button type="button" class="hero-btn" @onclick="Volver" disabled="@guardando">
                    Volver al checklist
                </button>
            </div>
        </section>

        <EditForm Model="vm" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="nuevo-hallazgo-grid">
                <section class="panel-card panel-main">
                    <div class="panel-head">
                        <div>
                            <h2>Datos del hallazgo</h2>
                            <p class="panel-subtitle">Completa la información principal para registrar el hallazgo.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Usuario actual</label>
                            <input class="form-control" value="@usuarioActualId" disabled />
                            <div class="field-help">
                                Este usuario quedará registrado como quien crea el hallazgo.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Nombre del usuario</label>
                            <input class="form-control" value="@usuarioActualNombre" disabled />
                            <div class="field-help">
                                Se toma desde la sesión autenticada.
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Fecha compromiso</label>
                            <InputDate class="form-control" @bind-Value="vm.FechaCompromiso" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Tipo de hallazgo</label>
                            <InputSelect class="form-select" @bind-Value="vm.TipoHallazgoId">
                                <option value="0">-- Selecciona --</option>
                                @foreach (var t in tiposHallazgo)
                                {
                                    <option value="@t.TipoHallazgoId">@t.Nombre</option>
                                }
                            </InputSelect>

                            @if (TipoSeleccionado is not null)
                            {
                                <div class="field-help">
                                    Severidad: <b>@TipoSeleccionado.Severidad</b>
                                </div>
                            }
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Responsable del hallazgo</label>
                            <InputSelect class="form-select" @bind-Value="vm.ResponsableId">
                                <option value="">-- Selecciona --</option>
                                @foreach (var u in usuariosDisponibles)
                                {
                                    <option value="@u.pc_login_id">@GetResponsableTexto(u)</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Responsable de finalizar el hallazgo</label>
                            <InputSelect class="form-select" @bind-Value="vm.ResponsableCierreId">
                                <option value="">-- Selecciona --</option>
                                @foreach (var u in usuariosDisponibles)
                                {
                                    <option value="@u.pc_login_id">@GetResponsableTexto(u)</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Descripción de la No Conformidad</label>
                            <InputTextArea class="form-control" @bind-Value="vm.DescripcionNoConformidad" rows="4" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Evidencia</label>
                            <InputTextArea class="form-control" @bind-Value="vm.Evidencia" rows="4" />
                            <div class="field-help">Opcional.</div>
                        </div>
                    </div>
                </section>

                <section class="panel-card panel-side">
                    <div class="panel-head">
                        <div>
                            <h2>Contexto del checklist</h2>
                            <p class="panel-subtitle">Información de referencia para documentar correctamente el hallazgo.</p>
                        </div>
                    </div>

                    <div class="context-card">
                        <div class="context-label">Proceso</div>
                        <div class="context-value">@ap.Proceso?.Codigo - @ap.Proceso?.Nombre</div>
                    </div>

                    <div class="context-card">
                        <div class="context-label">Pregunta</div>
                        <div class="context-value">@pregunta.Pregunta</div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(pregunta.Requisito))
                    {
                        <div class="context-card">
                            <div class="context-label">Requisito</div>
                            <div class="context-value small-text">@pregunta.Requisito</div>
                        </div>
                    }

                    @if (pregunta.Clausula is not null)
                    {
                        <div class="context-card">
                            <div class="context-label">Cláusula</div>
                            <div class="context-value">@pregunta.Clausula.Codigo - @pregunta.Clausula.Descripcion</div>
                        </div>
                    }

                    <div class="section-divider"></div>

                    <div class="mini-section-label">Responsables seleccionados</div>

                    @if (ResponsableSeleccionado is not null)
                    {
                        <div class="user-summary-card">
                            <div class="user-summary-role">Responsable del hallazgo</div>
                            <div class="user-summary-name">@GetNombreUsuario(ResponsableSeleccionado)</div>
                            <div class="user-summary-login">@ResponsableSeleccionado.pc_login_id</div>
                            <div class="user-summary-meta">
                                @ResponsableSeleccionado.department
                                @if (!string.IsNullOrWhiteSpace(ResponsableSeleccionado.position))
                                {
                                    <span> | @ResponsableSeleccionado.position</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(ResponsableSeleccionado.email))
                            {
                                <div class="user-summary-meta">@ResponsableSeleccionado.email</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state compact">
                            Aún no se ha seleccionado responsable del hallazgo.
                        </div>
                    }

                    @if (ResponsableCierreSeleccionado is not null)
                    {
                        <div class="user-summary-card">
                            <div class="user-summary-role">Responsable de cierre</div>
                            <div class="user-summary-name">@GetNombreUsuario(ResponsableCierreSeleccionado)</div>
                            <div class="user-summary-login">@ResponsableCierreSeleccionado.pc_login_id</div>
                            <div class="user-summary-meta">
                                @ResponsableCierreSeleccionado.department
                                @if (!string.IsNullOrWhiteSpace(ResponsableCierreSeleccionado.position))
                                {
                                    <span> | @ResponsableCierreSeleccionado.position</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(ResponsableCierreSeleccionado.email))
                            {
                                <div class="user-summary-meta">@ResponsableCierreSeleccionado.email</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state compact">
                            Aún no se ha seleccionado responsable de cierre.
                        </div>
                    }
                </section>
            </div>

            <section class="panel-card action-panel">
                <div class="action-panel-inner">
                    <div>
                        <h2>Confirmación</h2>
                        <p class="panel-subtitle mb-0">
                            Al guardar se creará el hallazgo y se registrará el seguimiento inicial.
                        </p>
                    </div>

                    <div class="action-buttons">
                        <button class="btn btn-danger btn-lg" type="submit" disabled="@guardando">
                            @(guardando ? "Guardando..." : "Guardar hallazgo")
                        </button>

                        <button class="btn btn-outline-secondary btn-lg" type="button" @onclick="Volver" disabled="@guardando">
                            Cancelar
                        </button>
                    </div>
                </div>
            </section>
        </EditForm>
    </div>
}

@code {
    [Parameter] public int auditoriaId { get; set; }
    [Parameter] public int auditoriaProcesoId { get; set; }
    [Parameter] public int preguntaId { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool cargando = true;
    private bool guardando;
    private string? errorMsg;

    private string usuarioActualId = "sistema";
    private string usuarioActualNombre = "sistema";

    private AuditoriaProceso? ap;
    private ChecklistPregunta? pregunta;
    private List<TipoHallazgo> tiposHallazgo = new();
    private List<MeaxAllUser> usuariosDisponibles = new();

    private Vm vm = new();

    private TipoHallazgo? TipoSeleccionado =>
        tiposHallazgo.FirstOrDefault(x => x.TipoHallazgoId == vm.TipoHallazgoId);

    private MeaxAllUser? ResponsableSeleccionado =>
        usuariosDisponibles.FirstOrDefault(x => x.pc_login_id == vm.ResponsableId);

    private MeaxAllUser? ResponsableCierreSeleccionado =>
        usuariosDisponibles.FirstOrDefault(x => x.pc_login_id == vm.ResponsableCierreId);

    private class Vm
    {
        public int TipoHallazgoId { get; set; }
        public DateTime FechaCompromiso { get; set; } = DateTime.Today.AddDays(7);
        public string? ResponsableId { get; set; }
        public string? ResponsableCierreId { get; set; }
        public string? DescripcionNoConformidad { get; set; }
        public string? Evidencia { get; set; }
    }

    protected override async Task OnParametersSetAsync()
    {
        cargando = true;
        errorMsg = null;

        await CargarUsuarioActual();

        ap = await Db.AuditoriaProcesos
            .Include(x => x.Proceso)
            .FirstOrDefaultAsync(x => x.AuditoriaProcesoId == auditoriaProcesoId && x.AuditoriaId == auditoriaId);

        pregunta = await Db.ChecklistPreguntas
            .Include(p => p.Clausula)
            .FirstOrDefaultAsync(p => p.PreguntaId == preguntaId);

        tiposHallazgo = await Db.TiposHallazgo
            .OrderBy(x => x.Severidad)
            .ThenBy(x => x.Nombre)
            .ToListAsync();

        usuariosDisponibles = await Db.MeaxAllUsers
            .AsNoTracking()
            .Where(x => !string.IsNullOrWhiteSpace(x.pc_login_id))
            .OrderBy(x => x.username ?? x.pc_login_id)
            .ToListAsync();

        if (string.IsNullOrWhiteSpace(vm.ResponsableId) && ExisteUsuarioEnCatalogo(usuarioActualId))
        {
            vm.ResponsableId = usuarioActualId;
        }

        if (string.IsNullOrWhiteSpace(vm.ResponsableCierreId) && ExisteUsuarioEnCatalogo(usuarioActualId))
        {
            vm.ResponsableCierreId = usuarioActualId;
        }

        if (pregunta is not null && string.IsNullOrWhiteSpace(vm.DescripcionNoConformidad))
        {
            vm.DescripcionNoConformidad = $"No cumple: {pregunta.Pregunta}";
        }

        cargando = false;
    }

    private async Task CargarUsuarioActual()
    {
        if (AuthenticationStateTask is null)
            return;

        var authState = await AuthenticationStateTask;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            usuarioActualId =
                user.FindFirst("pc_login_id")?.Value
                ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                ?? "sistema";

            usuarioActualNombre =
                user.Identity?.Name
                ?? user.FindFirst(ClaimTypes.Name)?.Value
                ?? usuarioActualId;
        }
    }

    private bool ExisteUsuarioEnCatalogo(string? loginId) =>
        !string.IsNullOrWhiteSpace(loginId) &&
        usuariosDisponibles.Any(x => x.pc_login_id == loginId);

    private string GetResponsableTexto(MeaxAllUser u)
    {
        var nombre = string.IsNullOrWhiteSpace(u.username) ? u.pc_login_id : u.username;
        var depto = string.IsNullOrWhiteSpace(u.department) ? "" : $" - {u.department}";
        return $"{nombre} ({u.pc_login_id}){depto}";
    }

    private static string GetNombreUsuario(MeaxAllUser u) =>
        string.IsNullOrWhiteSpace(u.username) ? u.pc_login_id : u.username!;

    private async Task Guardar()
    {
        if (guardando) return;
        guardando = true;
        errorMsg = null;

        try
        {
            if (ap is null || pregunta is null)
                return;

            if (string.IsNullOrWhiteSpace(usuarioActualId) || usuarioActualId == "sistema")
            {
                errorMsg = "No se pudo identificar el usuario autenticado.";
                return;
            }

            if (vm.TipoHallazgoId == 0)
            {
                errorMsg = "Selecciona un tipo de hallazgo.";
                return;
            }

            if (vm.FechaCompromiso < DateTime.Today)
            {
                errorMsg = "La fecha compromiso no puede ser anterior al día de hoy.";
                return;
            }

            if (string.IsNullOrWhiteSpace(vm.DescripcionNoConformidad))
            {
                errorMsg = "La descripción de la no conformidad es obligatoria.";
                return;
            }

            if (string.IsNullOrWhiteSpace(vm.ResponsableId))
            {
                errorMsg = "El responsable del hallazgo es obligatorio.";
                return;
            }

            if (string.IsNullOrWhiteSpace(vm.ResponsableCierreId))
            {
                errorMsg = "El responsable de finalizar el hallazgo es obligatorio.";
                return;
            }

            var existente = await Db.Hallazgos
                .AsNoTracking()
                .FirstOrDefaultAsync(h =>
                    h.AuditoriaProcesoId == auditoriaProcesoId &&
                    h.PreguntaId == preguntaId);

            if (existente is not null)
            {
                Nav.NavigateTo($"auditorias/{auditoriaId}/hallazgos/{existente.HallazgoId}");
                return;
            }

            var hallazgo = new Hallazgo
            {
                AuditoriaId = auditoriaId,
                ProcesoId = ap.ProcesoId,
                ClausulaId = pregunta.ClausulaId,
                TipoHallazgoId = vm.TipoHallazgoId,

                AuditoriaProcesoId = auditoriaProcesoId,
                PreguntaId = preguntaId,

                Descripcion = vm.DescripcionNoConformidad.Trim(),
                Evidencia = string.IsNullOrWhiteSpace(vm.Evidencia) ? null : vm.Evidencia.Trim(),

                ResponsableId = vm.ResponsableId.Trim(),
                ResponsableCierreId = vm.ResponsableCierreId.Trim(),

                FechaCompromiso = vm.FechaCompromiso,
                Estatus = "Abierto"
            };

            Db.Hallazgos.Add(hallazgo);
            await Db.SaveChangesAsync();

            Db.HallazgoSeguimientos.Add(new HallazgoSeguimiento
            {
                HallazgoId = hallazgo.HallazgoId,
                UsuarioId = usuarioActualId,
                Comentario = $"Creó el hallazgo. Responsable: {hallazgo.ResponsableId}. Responsable de cierre: {hallazgo.ResponsableCierreId}.",
                EstatusNuevo = hallazgo.Estatus
            });

            await Db.SaveChangesAsync();

            Nav.NavigateTo($"auditorias/{auditoriaId}/procesos/{auditoriaProcesoId}/checklist");
        }
        catch (Exception ex)
        {
            errorMsg = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            guardando = false;
        }
    }

    private void Volver() => Nav.NavigateTo($"auditorias/{auditoriaId}/procesos/{auditoriaProcesoId}/checklist");
}